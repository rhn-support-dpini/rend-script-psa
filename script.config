# =================================================================
# CONFIGURAZIONE GENERICA SCRIPT
# =================================================================
VERSIONE=1.0
AUTORE=Pini

# =================================================================
# FILTRO SETTIMANE
# =================================================================
# WeeksLimit: "yes" per limitare i calcoli all'intervallo [StartWeek, EndWeek).
#             "no" per includere tutti i dati.
WeeksLimit=no

# StartWeek / EndWeek: numero di settimana ISO (1-53).
#   StartWeek è inclusa, EndWeek è ESCLUSA dal filtro.
StartWeek=14
EndWeek=15

# =================================================================
# INDICI COLONNE FILE EXCEL DI INPUT
# =================================================================
# Decommentare solo se il layout del file sorgente differisce dai default.
#
#   ColIdxProgetto  (default 0) : nome contratto / progetto
#   ColIdxRuolo     (default 4) : ruolo/profilo della risorsa
#   ColIdxStimato   (default 7) : ore stimate (Estimated Hours)
#   ColIdxEffettivo (default 8) : ore consuntivate (Actual Hours)
#   ColIdxPeriodo   (default 9) : periodo nel formato CYyyyy-Www
#
# ColIdxProgetto=0
# ColIdxRuolo=4
# ColIdxStimato=7
# ColIdxEffettivo=8
# ColIdxPeriodo=9

# =================================================================
# INTESTAZIONI GENERICHE TAB PROGETTI
# =================================================================
Intestazione5=Red Hat Consulting Services - ITALY
Intestazione6=Summary table for used days on contracts
