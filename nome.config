# =================================================================
# CONFIGURAZIONE GENERALE REPORT
# =================================================================
# Versione dello script (riportata nel foglio 'dati', cella A1)
VERSIONE=1.0
AUTORE=Pini

# =================================================================
# FILTRO SETTIMANE
# =================================================================
# WeeksLimit: se impostato a "yes", i calcoli di ore/giornate vengono
#             eseguiti solo sulle righe il cui periodo rientra nell'
#             intervallo [StartWeek, EndWeek). Vengono inoltre aggiunte
#             note esplicative in fondo ai fogli 'progetti' ed 'Export'.
#             Se impostato a "no", tutti i dati vengono inclusi nel calcolo.
WeeksLimit=no

# StartWeek / EndWeek: numero di settimana ISO (1-53).
#   StartWeek è inclusa, EndWeek è ESCLUSA dal filtro.
#   Esempio: StartWeek=14, EndWeek=15 → solo la settimana 14.
StartWeek=14
EndWeek=15

# =================================================================
# INDICI COLONNE FILE EXCEL DI INPUT
# =================================================================
# Questi parametri definiscono quale colonna (0-based) del file Excel
# sorgente contiene le informazioni chiave. Modificarli solo se il
# formato del file di input cambia rispetto al layout standard PSA.
#
#   ColIdxProgetto  (default 0) : nome contratto / progetto
#   ColIdxRuolo     (default 4) : ruolo/profilo della risorsa
#   ColIdxStimato   (default 7) : ore stimate (Estimated Hours)
#   ColIdxEffettivo (default 8) : ore consuntivate (Actual Hours)
#   ColIdxPeriodo   (default 9) : periodo nel formato CYyyyy-Www
#
# ColIdxProgetto=0
# ColIdxRuolo=4
# ColIdxStimato=7
# ColIdxEffettivo=8
# ColIdxPeriodo=9

# =================================================================
# INTESTAZIONI TAB PROGETTI
# =================================================================
# Intestazione5 : titolo principale (riga 3, font 14pt grassetto)
# Intestazione6 : sottotitolo      (riga 4, font 12pt grassetto)
# Intestazione8a/9a/10a : informazioni cliente (righe 5-7)
Intestazione5=Red Hat Consulting Services - ITALY
Intestazione6=Summary table for used days on contracts
Intestazione8a=Customer: Intesa
Intestazione9a=Customer Name: Intesa
Intestazione10a=Customer Contact: Celli

# =================================================================
# CONFIGURAZIONE CONTRATTI E OPPORTUNITY
# =================================================================
# Per ogni contratto definire un gruppo di chiavi con lo stesso suffisso
# numerico progressivo (1, 2, 3, …):
#
#   ContractName<N>   : deve corrispondere ESATTAMENTE al valore nella
#                       colonna A del file Excel di input (case sensitive)
#   Opportunity<N>    : codice/nome opportunità (colonna C del foglio progetti)
#   EndDate<N>        : data di scadenza nel formato dd/mm/yyyy (colonna D).
#                       Le scadenze entro 2 settimane vengono evidenziate in giallo.
#   DaysRedempted<N>  : giorni riscattati nel formato "PM, Consulting"
#                       (colonne E e F del foglio progetti)

ContractName1=ISP_GPSteam25_coverage_Project-Budget
Opportunity1=INTESA SANPAOLO SPA-2025-10-23
EndDate1=27/09/2026
DaysRedempted1=10, 155

ContractName2=Renewal - INTESA SANPAOLO SPA - 00492170_Project-Budget
Opportunity2=Renewal - INTESA SANPAOLO SPA - 00492170
EndDate2=31/01/2027
DaysRedempted2=16, 237

ContractName3=Renewal - INTESA SANPAOLO SPA - 00492170_Project-Budget-Celli
Opportunity3=Renewal - INTESA SANPAOLO SPA - 00492170
EndDate3=31/01/2027
DaysRedempted3=27, 297

ContractName4=Renewal - INTESA SANPAOLO SPA - Subscription project
Opportunity4=Renewal - INTESA SANPAOLO SPA - 00492170
EndDate4=30/06/2026
DaysRedempted4=39, 390

# =================================================================
# CONFIGURAZIONE TABELLA DI EXPORT
# =================================================================
# Export1: testo del titolo nella riga 1 del foglio (sfondo verde scuro,
#          testo bianco, celle B-M unite). La data di produzione viene
#          aggiunta automaticamente dallo script.
Export1=Situazione giornate

# Export2: intestazioni delle colonne A-M separate da virgola (sfondo nero,
#          testo bianco). Devono essere esattamente 13 valori.
Export2=CODICE INTERNO,Codice offerta fornitore,Descrizione/Progetto ISP,Tecnologia fornitura,ODA ISP,Ref. ISP,Ref. fornitore,Tecnico fornitore,gg/u acquistati,gg/u consumati,gg/u residui,Totale ordine €,Tariffa media € gg/u

# Export3, Export4, … : righe di dati, una per riga.
# Formato: 13 campi separati da virgola (colonne A-M).
#   - Colonna A (campo 1): codice interno. Se questo valore è presente nella
#     colonna "Riferimento tabella 1" del file sorgente, lo script scrive
#     automaticamente in colonna J la somma delle ore consuntivate (÷ 8).
#   - Colonna I (campo 9): gg/u acquistati (inseriti manualmente).
#   - Colonna K (campo 11): calcolata automaticamente come I - J (formula Excel).
#   - Il separatore "-" come prima riga crea una riga separatore visivo.
#
# Nota: i valori in colonna 9 (gg/u acquistati) della copia arrotondata
#       vengono arrotondati all'intero più vicino dallo script.
Export3=team PaaS 2025-1,,team PaaS 2025,Consulenza,7200248669,Celli,Pini,Gruppo Residente Red Hat,165,,,,,1
Export4=team PaaS 2025-2,,team PaaS 2026,Consulenza,7200249275,Celli,Pini,Gruppo Residente Red Hat,162,,,,,2
Export5=team PaaS 2026-3,,team PaaS 2026,Consulenza,7200249275,Torrengo / Ferrarese,Pini,Red Hat,40,,,,,3
Export6=Banche Estere 2025-4,,Banche Estere 2025,Consulenza,,,Pini,Gruppo Residente Red Hat,16,,,,,4
Export7=Banche Estere 2026-5,,Banche Estere 2026,Consulenza,,,Pini,Gruppo Residente Red Hat,94,,,,,5
Export8=team PaaS 2026-6,,team PaaS 2026,Consulenza,7200249021 / 7200249511,Celli,Pini,Gruppo Residente Red Hat/(Sub),258,,,,,6
Export9=-,,,,,,,,,,,,,
Export10=Fideuram 2025-7,,Fideuram 2025,Consulenza,7200249021 / 7200249511,Celli / Contardi,Pini,Gruppo Residente Red Hat,50,,,,,7
Export11=Fideuram 2026-8,,Fideuram 2026,Consulenza,7200249021 / 7200249511,Celli / Contardi,Pini,Gruppo Residente Red Hat,10,,,,,8
Export12=Assicura-9,,Assicura,Consulenza,7200249021 / 7200249511,Mussini,Pini,Gruppo Residente Red Hat,5,,,,,9
Export13=Finanza-10,,Finanza,Consulenza,7200249021 / 7200249511,,Pini,Gruppo Residente Red Hat,30,,,,,10
